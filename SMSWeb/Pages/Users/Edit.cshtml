@page
@model SMSWeb.Pages.Users.EditModel
@{
    ViewData["Title"] = "Edit";
}
            <form method="post">
                    <input hidden asp-for="@Model.UserObj.Id" />
                    
                    <div class="border p-3 mt-4">
                        <div class="row pb-2">
                            <h2 class="text-primary pl-3">Edit User</h2>
                            <hr/>
                        </div>
                        
                        <div asp-validation-summary="All"></div>

                        <div class="mb-3">
                            <label asp-for="@Model.UserObj.Name" class="form-label">Name</label>
                            <input asp-for="@Model.UserObj.Name" class="form-control" />
                            <span asp-validation-for="@Model.UserObj.Name" class="text-danger"></span>
                        </div>
             
                          
                        <div class="mb-3">
                                <label asp-for="UserObj.Address" class="form-label">Address</label>
                                 <input asp-for="UserObj.Address" class="form-control" />
                              <span asp-validation-for="UserObj.Address" class="text-danger"></span>
                        </div>
               

              
                        <div class="mb-3">
                        <label asp-for="UserObj.Phone" class="form-label">Phone</label>
                            <input asp-for="UserObj.Phone" class="form-control" />
                            <span asp-validation-for="UserObj.Phone" class="text-danger"></span>
                        </div>
              

             
                        <div class="mb-3">
                            <label asp-for="UserObj.Role" class="form-label">Role</label>
                            <input asp-for="UserObj.Role" class="form-control" />
                             <span asp-validation-for="UserObj.Role" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">Edit</button>
                    </div>

            </form>


@section Scripts{
    @{
        <partial name="_ValidationScriptsPartial"/>
    }
}

