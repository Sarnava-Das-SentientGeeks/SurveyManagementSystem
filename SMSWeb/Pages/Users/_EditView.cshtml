
@model SurveyManagementSystem.BLL.Entities.User
@using SurveyManagementSystem.BLL.Entities;



@* This is used when there is submit button in the form onsubmit="return false;" *@
<form>
    <input hidden asp-for="@Model.Id" />
    <div class="modal-header">
        <h5 class="modal-title">Edit User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
                

    <div class="modal-body">
        <div class="mb-3">
            <label asp-for="@Model.Name" class="form-label">Name</label>
            <input asp-for="@Model.Name" id="Name" class="form-control" />
            <span asp-validation-for="@Model.Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Address" class="form-label">Address</label>
            <input asp-for="@Model.Address" id="Address" class="form-control" />
            <span asp-validation-for="@Model.Address" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Phone" class="form-label">Phone</label>
            <input asp-for="@Model.Phone" id="Phone" class="form-control" />
            <span asp-validation-for="@Model.Phone" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <select id="Roles" asp-items="@(new SelectList(ViewData["RoleList"] as IEnumerable<Role>, "Id", "Name"))" class="form-select">
                <option value="" selected disabled>Select Role</option>             
            </select>
        </div>

       
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="updateUser(@Model.Id)">Update</button>
    </div>


</form>


@section Scripts {


    @{
        <partial name="_ValidationScriptsPartial" />
    }
   
}

