
@model SurveyManagementSystem.BLL.Entities.User

<form>
    <input hidden asp-for="@Model.Id" />
    <div class="modal-header">
        <h5 class="modal-title">Edit User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
                

    <div class="modal-body">
        <div class="mb-3">
            <label asp-for="@Model.Name" class="form-label">Name</label>
            <input asp-for="@Model.Name" class="form-control" />
            <span asp-validation-for="@Model.Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Address" class="form-label">Name</label>
            <input asp-for="@Model.Address" class="form-control" />
            <span asp-validation-for="@Model.Address" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Phone" class="form-label">Name</label>
            <input asp-for="@Model.Phone" class="form-control" />
            <span asp-validation-for="@Model.Phone" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Role" class="form-label">Name</label>
            <input asp-for="@Model.Role" class="form-control" />
            <span asp-validation-for="@Model.Role" class="text-danger"></span>
        </div>
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Update</button>                    
    </div>
</form>


