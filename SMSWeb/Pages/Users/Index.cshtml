@page
@model SMSWeb.Pages.Users.IndexModel

@{
    ViewData["Title"] = "User List";
}




<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">User List</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-page="Create" class="btn btn-primary">
                <i class="bi bi-plus-square-fill"></i>&nbsp; Add User
            </a>
        </div>
    </div>

    <br/></<br />

    <table class="table table-bordered table-striped" style="max-width:100%">
        <thead>
            <tr>
            
                <th>@Html.DisplayNameFor(Model=>Model.UserList.First().Name)</th> 
                <th>@Html.DisplayNameFor(Model => Model.UserList.First().Address)</th>
                <th>@Html.DisplayNameFor(Model => Model.UserList.First().Phone)</th>
             
              
                <th></th>
            </tr>
        </thead>
        
        <tbody>
            @foreach(var obj in Model.UserList)
            {
                <tr>
                    <td>@obj.Name</td>
                    <td>@obj.Address</td>
                    <td>@obj.Phone</td>
                  
                  <td>
                    <div class="w-75 btn-group" role="group"> 
                            <a class="btn btn-primary mx-2" onclick="openEditModal(@obj.Id)"><i class="bi bi-pencil">Edit</i></a>
                            <a class="btn btn-danger mx-2" onclick="openModal(@obj.Id)" ><i class="bi bi-trash3-fill"></i> </a>
                    </div>
                   </td>
                </tr>
            }
           
        </tbody>
    </table>
</div>

<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" id="editContent"></div>
    </div>
</div>

@section Scripts{


  <script src = "/js/site.js"> </script>
} 


