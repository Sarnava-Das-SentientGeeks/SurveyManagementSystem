@page
@model SMSWeb.Pages.Users.DetailsModel
@{
    ViewData["Title"] = "Detials";
}
    
<div class="container p-3">
    <div class="row pt-4">
        <div class="col-12">
            <h2 class="text-primary">User List</h2>
        </div>
       
    </div>

    <br /></<br />
        
        
        <table class="table table-bordered table-striped" >
                   <thead>
                       <tr>
                <th>@Html.DisplayNameFor(u => u.UserList.First().Name)</th>
                <th>@Html.DisplayNameFor(u => u.UserList.First().Address)</th>
                <th>@Html.DisplayNameFor(u => u.UserList.First().Phone)</th>
              
                       </tr>
                   </thead>
                   <tbody>
                  
                         @foreach(var item in Model.UserList)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td>@item.Address</td>
                                    <td>@item.Phone</td>
                                   
                                </tr>
                
                            }
                   
                   </tbody>
               </table>
</div>


@section Scripts{
    @{
        <partial name="_ValidationScriptsPartial"/>
    }
}

