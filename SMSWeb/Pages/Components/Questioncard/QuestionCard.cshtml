
@* Here class name is question-card for selecting it in jQuery *@
<div class="card border-secondary mb-3 question-card" id="question-card-0" style="max-width:auto;">
    <div class="card-body">
        <div class="row">
            <div class="col-6">
                <input class="form-control question-input" value="Question" id="question-input-0" />
            </div>
            <div class="col-6">
                <select class="form-select question-type" value="Options" id="question-type-0">
                    <option value="" selected disabled>Select Question Type</option>
                    <option value="1">Short text</option>
                    <option value="2">Multiple Choice</option>
                    <option value="3">Checkboxes</option>     

                </select>

            </div>
        </div>
        @* <div class="row" hidden>
            @await Component.InvokeAsync("Radiobuttons");
        </div> *@
        <div class="row" id="checkboxContainer" hidden>
            @await Component.InvokeAsync("Checkboxes");
        </div>
        <button type="button" onclick="addQuestion(this.closest('.question-card').id)"><i class="bi bi-plus-circle-fill"></i></button>
        @* <button type="button" onclick="addQuestion(this)"><i class="bi bi-plus-circle-fill"></i></button> passes the button itself *@
        <button type="button" onclick="this.closest('.card').remove()"><i class="bi bi-trash-fill"></i></button>
 
    </div>
</div>